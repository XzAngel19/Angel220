--// Rendering Loop for ESP
local ESPCache = {}

local function ClearESP(instance)
    if ESPCache[instance] then
        ESPCache[instance]:Destroy()
        ESPCache[instance] = nil
    end
end

local function DrawESP(instance, color, text)
    if not instance then return end
    if ESPCache[instance] then
        ESPCache[instance].OutlineColor = color
        ESPCache[instance].FillColor = color
        return
    end

    local Highlight = Instance.new("Highlight")
    Highlight.Name = "YARHM_ESP"
    Highlight.Adornee = instance
    Highlight.FillTransparency = 0.5
    Highlight.OutlineTransparency = 0
    Highlight.FillColor = color
    Highlight.OutlineColor = color
    Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    Highlight.Parent = CoreGui
    ESPCache[instance] = Highlight
end

RunService.RenderStepped:Connect(function()
    ScanRolesLocally()

    -- Player ESP
    if Settings.RoleESP then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local char = player.Character
                local espColor = C_Green
                if player == Roles.Murderer then espColor = C_Red
                elseif player == Roles.Sheriff then espColor = C_Blue end
                DrawESP(char, espColor, player.Name)
            else
                ClearESP(player.Character)
            end
        end
    else
        for _, player in pairs(Players:GetPlayers()) do
            ClearESP(player.Character)
        end
    end

    -- Gun / Trap ESP
    if Settings.GunESP or Settings.TrapESP then
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == "GunDrop" and Settings.GunESP then
                DrawESP(obj, Color3.fromRGB(255, 255, 0), "Gun")
            elseif obj:IsA("Part") and obj.Name == "TrapVisual" and Settings.TrapESP then
                DrawESP(obj, Color3.fromRGB(200, 100, 255), "Trap")
            end
        end
    end
end)

