--// Utility logic
local function GetPing()
    local stats = game:GetService("Stats")
    local network = stats:FindFirstChild("Network")
    if network and network:FindFirstChild("ServerStatsItem") and network.ServerStatsItem:FindFirstChild("Data Ping") then
        return network.ServerStatsItem["Data Ping"]:GetValue()
    end
    return 100
end

local function ScanRolesLocally()
    Roles.Murderer = nil
    Roles.Sheriff = nil
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local bp = player:FindFirstChild("Backpack")
            local char = player.Character

            local possibleTools = {}
            if bp then for _, t in pairs(bp:GetChildren()) do table.insert(possibleTools, t) end end
            for _, t in pairs(char:GetChildren()) do table.insert(possibleTools, t) end

            for _, tool in pairs(possibleTools) do
                if tool:IsA("Tool") then
                    if tool.Name == "Knife" or tool:FindFirstChild("KnifeClient") or tool:HasTag("Weapon_Knife") then
                        Roles.Murderer = player
                    elseif tool.Name == "Gun" or tool:FindFirstChild("GunClient") or tool:HasTag("Weapon_Gun") then
                        Roles.Sheriff = player
                    end
                end
            end
        end
    end
end

